{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canonical Tool Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "toolId",
    "version",
    "displayName",
    "description",
    "category",
    "executionMode",
    "riskLevel",
    "approvalRequired",
    "supportsDryRun",
    "supportsReplay",
    "rollbackSupported",
    "inputSchemaRef",
    "outputSchemaRef",
    "policyRef"
  ],
  "properties": {
    "toolId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["filesystem", "network", "database", "memory", "planner", "formatter", "audit", "approval", "replay", "system"]
    },
    "executionMode": {
      "type": "string",
      "enum": ["read_only", "controlled", "approval_required", "disabled"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "approvalRequired": { "type": "boolean" },
    "supportsDryRun": { "type": "boolean" },
    "supportsReplay": { "type": "boolean" },
    "rollbackSupported": { "type": "boolean" },
    "inputSchemaRef": { "type": "string", "minLength": 1 },
    "outputSchemaRef": { "type": "string", "minLength": 1 },
    "policyRef": { "type": "string", "minLength": 1 }
  }
}
