{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Filesystem Write Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["path", "content"],
  "properties": {
    "path": { "type": "string", "minLength": 1 },
    "content": { "type": "string" },
    "encoding": { "type": "string", "enum": ["utf8"] }
  }
}
