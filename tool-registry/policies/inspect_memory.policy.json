{
  "policyId": "inspect_memory.policy",
  "toolId": "inspect_memory",
  "version": "1.0.0",
  "allowedScopes": ["localhost-read"],
  "forbiddenScopes": ["external-host"],
  "timeoutMs": 3000,
  "sideEffects": [],
