generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  viewer
  operator
  approver
  admin
}

enum UserStatus {
  active
  disabled
}

enum WorkspaceMemberRole {
  owner
  admin
  member
  viewer
}

enum WorkspaceInviteStatus {
  pending
  accepted
  revoked
}

enum SourceType {
  website
  repository
  integration
  feed
  document
}

enum SourceStatus {
  healthy
  degraded
  paused
}

enum AlertStatus {
  unread
  read
  archived
}

enum AlertSeverity {
  info
  warning
  critical
}

enum UpdateSeverity {
  low
  medium
  high
  critical
}

enum InsightType {
  summary
  insight
  recommendation
  classification
}

enum InsightStatus {
  ready
  draft
  archived
}

enum AgentTaskStatus {
  queued
  running
  completed
  failed
  canceled
}

enum AgentExecutionStatus {
  running
  completed
  failed
}

enum BriefStatus {
  draft
  queued
  in_progress
  in_review
  complete
}

enum BriefPriority {
  low
  medium
  high
}

enum ReportFormat {
  memo
  briefing
  comparison
  outline
}

enum ReportStatus {
  draft
  ready
  published
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String
  role         UserRole          @default(operator)
  status       UserStatus        @default(active)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  sessions     AuthSession[]
  activities   ActivityEvent[]
  briefs       ResearchBrief[]
  reports      ResearchReport[]
  savedViews   SavedView[]
  alerts       Alert[]
  createdInvites WorkspaceInvite[] @relation("CreatedWorkspaceInvites")
  acceptedInvites WorkspaceInvite[] @relation("AcceptedWorkspaceInvites")
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String
  plan        String            @default("scale")
  statusTone  String            @default("healthy")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  sources     Source[]
  updates     MonitoredUpdate[]
  insights    Insight[]
  activity    ActivityEvent[]
  savedViews  SavedView[]
  briefs      ResearchBrief[]
  reports     ResearchReport[]
  invites     WorkspaceInvite[]
  alerts      Alert[]
  featureFlags WorkspaceFeatureFlag[]
  agentTasks  AgentTask[]
  operationsState WorkspaceOperationsState?
  operationsFollowups OperationsFollowup[]
  incidentApprovals IncidentApprovalRequest[]
  policyOverride WorkspacePolicyOverride?
  playbookRolloutWorkspaces PolicyPlaybookRolloutWorkspace[]
}

model WorkspaceInvite {
  id               String                @id @default(cuid())
  token            String                @unique
  email            String?
  workspaceId      String
  createdById      String
  status           WorkspaceInviteStatus @default(pending)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  acceptedAt       DateTime?
  acceptedByUserId String?
  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User                  @relation("CreatedWorkspaceInvites", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedBy       User?                 @relation("AcceptedWorkspaceInvites", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([email, status])
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceMemberRole @default(member)
  isDefault   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userAgent  String?
  ipHash     String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Source {
  id            String            @id @default(cuid())
  workspaceId   String
  name          String
  type          SourceType
  status        SourceStatus      @default(healthy)
  url           String?
  updateCadence String
  description   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updates       MonitoredUpdate[]
  alerts        Alert[]
}

model MonitoredUpdate {
  id          String         @id @default(cuid())
  workspaceId String
  sourceId    String
  title       String
  summary     String
  status      String
  severity    UpdateSeverity @default(medium)
  category    String
  happenedAt  DateTime
  createdAt   DateTime       @default(now())
  metadata    Json?
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source      Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  alerts      Alert[]
}

model Insight {
  id          String        @id @default(cuid())
  workspaceId String
  title       String
  summary     String
  type        InsightType
  status      InsightStatus @default(ready)
  confidence  Int
  score       Int           @default(0)
  sourceIds   String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  metadata    Json?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  alerts      Alert[]
}

model Alert {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String?
  sourceId    String?
  updateId    String?
  insightId   String?
  type        String
  title       String
  message     String
  severity    AlertSeverity @default(info)
  status      AlertStatus   @default(unread)
  readAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  source      Source?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  update      MonitoredUpdate? @relation(fields: [updateId], references: [id], onDelete: SetNull)
  insight     Insight?      @relation(fields: [insightId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([userId, status])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaceOverrides WorkspaceFeatureFlag[]
}

model WorkspaceFeatureFlag {
  id          String   @id @default(cuid())
  workspaceId String
  flagId      String
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  flag        FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, flagId])
  @@index([workspaceId, enabled])
}

model AgentTask {
  id          String        @id @default(cuid())
  workspaceId String
  type        String
  status      AgentTaskStatus @default(queued)
  input       Json?
  output      Json?
  requestedById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions  AgentExecution[]

  @@index([workspaceId, status])
}

model AgentExecution {
  id          String            @id @default(cuid())
  taskId      String
  status      AgentExecutionStatus @default(running)
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  error       String?
  metadata    Json?
  task        AgentTask         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, status])
}

model ActivityEvent {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  type        String
  title       String
  description String
  createdAt   DateTime  @default(now())
  metadata    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

model SavedView {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  name        String
  description String
  filters     Json
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ResearchBrief {
  id            String         @id @default(cuid())
  workspaceId   String
  ownerId       String?
  title         String
  question      String
  status        BriefStatus    @default(draft)
  priority      BriefPriority  @default(medium)
  assignedAgent String
  tags          String[]
  summary       String
  linkedTaskId  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  reports       ResearchReport[]
}

model ResearchReport {
  id          String       @id @default(cuid())
  workspaceId String
  briefId     String
  ownerId     String?
  title       String
  format      ReportFormat
  status      ReportStatus @default(draft)
  excerpt     String
  keyFindings String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brief       ResearchBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  owner       User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

model WorkspaceOperationsState {
  id                           String    @id @default(cuid())
  workspaceId                  String    @unique
  escalationOwner              String?
  incidentApproverTarget       String?
  backupApproverTarget         String?
  snoozedUntil                 DateTime?
  resolutionTaskId             String?
  resolutionCompletedAt        DateTime?
  resolutionDescription        String?
  resolutionOwnerName          String?
  incidentSummary              String?
  incidentSummaryUpdatedAt     DateTime?
  incidentHandoffDraft         String?
  incidentHandoffDraftUpdatedAt DateTime?
  incidentArchiveRecommendation String?
  incidentStatus               String    @default("open")
  incidentStatusUpdatedAt      DateTime?
  incidentChecklist            Json?
  lastSweepRunAt               DateTime?
  lastSweepQueuedAt            DateTime?
  lastGeneratedCount           Int       @default(0)
  lastSweepError               String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  workspace                    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model OperationsFollowup {
  id              String    @id @default(cuid())
  workspaceId     String
  agentName       String
  description     String
  status          String    @default("queued")
  priority        Int       @default(2)
  ownerId         String?
  ownerName       String?
  linkedInboxItemId String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model IncidentApprovalRequest {
  id                String    @id @default(cuid())
  workspaceId       String
  label             String
  requestedStatus   String
  status            String    @default("pending")
  approverTarget    String?
  routingMode       String?
  routingReason     String?
  routedFromTarget  String?
  requestedById     String?
  requestedByName   String?
  approvedById      String?
  approvedByName    String?
  rejectedById      String?
  rejectedByName    String?
  rejectionNote     String?
  archiveRationale  String?
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([approverTarget, status])
}

model PlatformGovernanceSettings {
  id                               String   @id @default("default")
  currentEnvironment               String   @default("development")
  sensitiveActionsRequireApproval  Boolean  @default(true)
  demoScenarioId                   String?
  demoScenarioName                 String?
  demoScenarioDescription          String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model EnvironmentPolicy {
  id                                  String   @id @default(cuid())
  environment                         String   @unique
  minimumRoleForCommands              String
  minimumRoleForApprovals             String
  minimumRoleForGovernance            String
  requireChecklistForResolved         Boolean  @default(false)
  requiredChecklistForResolved        String[]
  requireSummaryShareBeforeArchived   Boolean  @default(false)
  requireApprovalForResolved          Boolean  @default(false)
  requireApprovalForArchived          Boolean  @default(false)
  incidentApprovalReminderMinutes     Int      @default(30)
  incidentApprovalEscalationMinutes   Int      @default(60)
  incidentApprovalEscalationTarget    String   @default("team")
  incidentApprovalFinalEscalationMinutes Int   @default(120)
  incidentApprovalFinalEscalationTarget String @default("role:admin")
  incidentApprovalCapacityLimit       Int      @default(3)
  autoPromoteApprovalRecommendations  Boolean  @default(false)
  autoPromoteRecommendationConfidence Float    @default(0.9)
  autoPromoteObservationHours         Int      @default(24)
  autoPromoteCooldownHours            Int      @default(72)
  trustDropAction                     String   @default("notify")
  trustDropFollowupOwner              String?
  promoteTrustDropToIncident          Boolean  @default(false)
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt
}

model WorkspacePolicyOverride {
  id                              String   @id @default(cuid())
  workspaceId                     String   @unique
  environment                     String?
  incidentApprovalCapacityLimit   Int?
  incidentApprovalReminderMinutes Int?
  trustDropAction                 String?
  trustDropFollowupOwner          String?
  requireApprovalForResolved      Boolean?
  requireApprovalForArchived      Boolean?
  promoteTrustDropToIncident      Boolean?
  sourceType                      String?
  sourcePlaybookId                String?
  updatedById                     String?
  updatedByName                   String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
  workspace                       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcePlaybook                  PolicyPlaybook? @relation(fields: [sourcePlaybookId], references: [id], onDelete: SetNull)

  @@index([sourcePlaybookId])
}

model PolicyPlaybook {
  id                            String   @id
  name                          String
  environment                   String
  incidentApprovalCapacityLimit Int
  trustDropAction               String
  requireApprovalForResolved    Boolean  @default(false)
  promoteTrustDropToIncident    Boolean  @default(false)
  description                   String?
  isPreset                      Boolean  @default(false)
  createdById                   String?
  createdByName                 String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  rollouts                      PolicyPlaybookRollout[]
  sourcedOverrides              WorkspacePolicyOverride[]
}

model PolicyPlaybookRollout {
  id             String   @id @default(cuid())
  playbookId     String
  environment    String
  workspaceCount Int      @default(0)
  appliedById    String?
  appliedByName  String?
  createdAt      DateTime @default(now())
  rolledBackAt   DateTime?
  playbook       PolicyPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  workspaces     PolicyPlaybookRolloutWorkspace[]

  @@index([playbookId, createdAt])
}

model PolicyPlaybookRolloutWorkspace {
  id               String   @id @default(cuid())
  rolloutId        String
  workspaceId      String
  workspaceName    String
  beforeOverride   Json?
  afterOverride    Json?
  createdAt        DateTime @default(now())
  rollout          PolicyPlaybookRollout @relation(fields: [rolloutId], references: [id], onDelete: Cascade)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([rolloutId, workspaceId])
  @@index([workspaceId, createdAt])
}

model ConstitutionalResilienceStateRecord {
  resilienceId             String   @id @map("resilience_id")
  resilienceState          String   @map("resilience_state")
  continuityMode           String   @map("continuity_mode")
  survivabilityConfidence  Float    @map("survivability_confidence")
  constitutionalIntegrity  Float    @map("constitutional_integrity")
  operationalStability     Float    @map("operational_stability")
  createdAt                DateTime @map("created_at")

  @@map("constitutional_resilience_state")
}

model ConstitutionalReadinessAssessmentRecord {
  readinessAssessmentId          String   @id @map("readiness_assessment_id")
  readinessState                String   @map("readiness_state")
  readinessConfidence           Float    @map("readiness_confidence")
  governanceReliability         Float    @map("governance_reliability")
  auditIntegrity                Float    @map("audit_integrity")
  containmentSurvivability      Float    @map("containment_survivability")
  enforcementConsistency        Float    @map("enforcement_consistency")
  constitutionalSafe            Boolean  @map("constitutional_safe")
  advisoryOnly                  Boolean  @map("advisory_only")
  generatedAt                   DateTime @map("generated_at")

  @@map("constitutional_readiness_assessments")
}

model CollapsePreventionEvent {
  preventionEventId             String   @id @map("prevention_event_id")
  collapseRisk                  Float    @map("collapse_risk")
  protectedDomains              Json     @map("protected_domains")
  containmentActions            Json     @map("containment_actions")
  escalationActions             Json     @map("escalation_actions")
  survivabilityResult           String   @map("survivability_result")
  createdAt                     DateTime @map("created_at")

  @@map("collapse_prevention_events")
}

model ConstitutionalSovereigntyStateRecord {
  sovereigntyId             String   @id @map("sovereignty_id")
  sovereigntyState          String   @map("sovereignty_state")
  constitutionalIntegrity   Float    @map("constitutional_integrity")
  survivabilityConfidence   Float    @map("survivability_confidence")
  operationalStability      Float    @map("operational_stability")
  governanceReliability     Float    @map("governance_reliability")
  createdAt                 DateTime @map("created_at")

  @@map("constitutional_sovereignty_state")
}

model CivilizationGovernanceLedgerRecord {
  ledgerId                  String   @id @map("ledger_id")
  sovereigntyState          String   @map("sovereignty_state")
  validationState           String   @map("validation_state")
  operatorSupremacyPreserved Boolean @map("operator_supremacy_preserved")
  advisoryOnly              Boolean  @map("advisory_only")
  blockedReasons            Json     @map("blocked_reasons")
  createdAt                 DateTime @map("created_at")

  @@map("civilization_governance_ledger")
}

model SovereignRiskRegistryRecord {
  registryId                String   @id @map("registry_id")
  sovereigntyState          String   @map("sovereignty_state")
  systemicRisk              Float    @map("systemic_risk")
  autonomyRisk              Float    @map("autonomy_risk")
  civilizationScaleRisk     Float    @map("civilization_scale_risk")
  unstableSystems           Json     @map("unstable_systems")
  frozenSystems             Json     @map("frozen_systems")
  createdAt                 DateTime @map("created_at")

  @@map("sovereign_risk_registry")
}

model ConstitutionalValidationResultRecord {
  validationId              String   @id @map("validation_id")
  validationState           String   @map("validation_state")
  severity                  String   @map("severity")
  constitutionalSafe        Boolean  @map("constitutional_safe")
  survivabilitySafe         Boolean  @map("survivability_safe")
  autonomySafe              Boolean  @map("autonomy_safe")
  governanceIntegrity       Float    @map("governance_integrity")
  containmentIntegrity      Float    @map("containment_integrity")
  operationalStability      Float    @map("operational_stability")
  failures                  Json     @map("failures")
  warnings                  Json     @map("warnings")
  disputedSystems           Json     @map("disputed_systems")
  rollbackRequired          Boolean  @map("rollback_required")
  containmentRequired       Boolean  @map("containment_required")
  escalationRequired        Boolean  @map("escalation_required")
  immutableAuditVerified    Boolean  @map("immutable_audit_verified")
  createdAt                 DateTime @map("created_at")

  @@map("constitutional_validation_results")
}

model RuntimeChaosEventRecord {
  chaosEventId              String   @id @map("chaos_event_id")
  replayCorrupted           Boolean  @map("replay_corrupted")
  containmentFailed         Boolean  @map("containment_failed")
  escalationStorm           Boolean  @map("escalation_storm")
  dependencyCollapse        Boolean  @map("dependency_collapse")
  validationState           String   @map("validation_state")
  severity                  String   @map("severity")
  createdAt                 DateTime @map("created_at")

  @@map("runtime_chaos_events")
}

model GovernanceConflictEventRecord {
  conflictEventId           String   @id @map("conflict_event_id")
  disputedSystems           Json     @map("disputed_systems")
  constitutionalSafe        Boolean  @map("constitutional_safe")
  containmentRequired       Boolean  @map("containment_required")
  escalationRequired        Boolean  @map("escalation_required")
  blockedReasons            Json     @map("blocked_reasons")
  createdAt                 DateTime @map("created_at")

  @@map("governance_conflict_events")
}
