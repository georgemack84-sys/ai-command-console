# GitHub Environment: staging

DEPLOY_HOST=staging.example.com
DEPLOY_PORT=22
DEPLOY_USER=deploy
DEPLOY_PATH=/srv/ai-command-console/staging
DEPLOY_RESTART_COMMAND=systemctl restart ai-command-console-staging
DEPLOY_HEALTHCHECK_URL=https://staging.example.com/api/ready
DEPLOY_HEALTHCHECK_PATH=/api/ready
DEPLOY_HEALTHCHECK_ATTEMPTS=12
DEPLOY_HEALTHCHECK_DELAY_SECONDS=10
DEPLOY_VALIDATION_PATHS=/api/health,/api/ready,/auth
DEPLOY_RELEASE_RETENTION=5
DEPLOY_ARTIFACT_ONLY=false

# Host runtime environment
AI_COMMAND_CONSOLE_AUTH_SECRET=replace-me
DATABASE_URL=postgresql://app:secret@db.internal:5432/ai_command_console?schema=public
NEXT_PUBLIC_APP_URL=https://staging.example.com
AI_COMMAND_CONSOLE_STORAGE_DRIVER=sqlite
AI_COMMAND_CONSOLE_DATABASE_PATH=/srv/ai-command-console/shared/workspace.sqlite
AI_COMMAND_CONSOLE_AGENTS_DATABASE_PATH=/srv/ai-command-console/shared/agents-console.sqlite
AI_COMMAND_CONSOLE_SECURE_COOKIES=true
AI_COMMAND_CONSOLE_SESSION_MAX_AGE_SECONDS=1209600
AI_COMMAND_CONSOLE_ALERT_WEBHOOK_URL=https://hooks.example.com/staging-alerts
AI_COMMAND_CONSOLE_ALERT_WEBHOOK_SEVERITIES=high,critical
AI_COMMAND_CONSOLE_ALERT_WEBHOOK_THROTTLE_SECONDS=900
