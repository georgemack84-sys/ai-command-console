{
  "name": "ai-command-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.cjs dev",
    "dev:doctor": "node scripts/dev-doctor.cjs",
    "dev:bootstrap": "node scripts/dev-bootstrap.cjs",
    "dev:state-report": "node scripts/dev-state-report.cjs",
    "dev:state-archive": "node scripts/dev-state-archive.cjs",
    "dev:state-cleanup": "node scripts/dev-state-cleanup.cjs",
    "check:legacy-state": "node scripts/check-legacy-state.cjs",
    "dev:postgres:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-postgres-windows.ps1",
    "worker:jobs": "tsx scripts/job-worker.ts",
    "build": "node scripts/run-next.cjs build --webpack",
    "build:debug-prerender": "node node_modules/next/dist/bin/next build --webpack --debug-prerender",
    "start": "node scripts/run-next.cjs start",
    "postinstall": "prisma generate",
    "preflight": "node scripts/preflight.cjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset:local": "npm run db:deploy && npm run db:seed",
    "db:studio": "prisma studio",
    "backup:sqlite": "node scripts/backup-sqlite.cjs",
    "deployment:inventory": "node scripts/deployment-inventory.cjs",
    "validate:deploy-config": "node scripts/validate-deploy-config.cjs",
    "verify:backup": "node scripts/verify-sqlite-backup.cjs",
    "restore:sqlite": "node scripts/restore-sqlite.cjs",
    "validate:deploy": "node scripts/validate-deploy.cjs",
    "lint": "eslint",
    "test:unit": "vitest run --config vitest.config.mjs --coverage",
    "test:legacy": "npm run test:legacy:console",
    "test:legacy:core": "node --test --test-concurrency=1 --test-isolation=none tests/console-api-core.test.mjs",
    "test:legacy:collaboration": "node --test --test-concurrency=1 --test-isolation=none tests/console-api-collaboration.test.mjs",
    "test:legacy:operations": "node --test --test-concurrency=1 --test-isolation=none tests/console-api-operations.test.mjs",
    "test:legacy:trust": "node --test --test-concurrency=1 --test-isolation=none tests/console-api-trust.test.mjs",
    "test:legacy:workflows": "node --test --test-concurrency=1 --test-isolation=none tests/console-workflows.test.mjs",
    "test:legacy:scheduler": "node --test --test-concurrency=1 --test-isolation=none tests/scheduler-regressions.test.mjs",
    "test:legacy:console": "npm run test:legacy:core && npm run test:legacy:collaboration && npm run test:legacy:operations && npm run test:legacy:trust && npm run test:legacy:workflows && npm run test:legacy:scheduler",
    "test:legacy:compat": "node --test --test-concurrency=1 --test-isolation=none tests/console-api.test.mjs",
    "test:e2e": "playwright test",
    "ui:check": "playwright test",
    "ui:review": "playwright test playwright/ui-review.spec.ts --project=desktop-chromium",
    "stress:jobs": "node scripts/stress-jobs.cjs",
    "test": "npm run test:unit && npm run test:legacy",
    "verify:local": "npm run lint && npm run test:unit && npm run test:legacy && npm run build && npm run check:legacy-state -- --strict",
    "verify": "npm run lint && npm test && npm run build && npm run check:legacy-state -- --strict"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@sentry/node": "^8.14.0",
    "@prisma/client": "^6.2.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "inquirer": "^8.2.7",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.20.0",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "openai": "^6.32.0",
    "ora": "^5.4.1",
    "posthog-node": "^4.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "description": "Multi-agent command console with research workflows and governed operations tooling.",
  "keywords": [
    "ai",
    "console",
    "operations",
    "research",
    "nextjs"
  ],
  "author": "",
  "license": "ISC"
}
